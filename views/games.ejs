<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Games List</title>
</head>
<body>
  <h1>Video Game Database</h1>
  <ul>
    <% games.forEach(game => { %>
      <li>
        <%= game.title %>
      </li>
    <% }) %>
  </ul>
</body>
</html>