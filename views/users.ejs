<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users Info</title>
</head>

<body>
  <h1>Users Info</h1>
  <ul>
    <% users.forEach(user => { %>
    <li>
      <a href="/users/view/<%= user.id %>">
        <%= user.username %>
      </a>
    </li>
    <% }) %>
  </ul>
  <a href="/games/view">Games</a>
</body>

</html>